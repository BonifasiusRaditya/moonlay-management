# App runtime
APP_HOST=localhost
APP_PORT=3001
APP_ENDPOINT_V=v1
APP_ENVIRONMENT=DEVELOPMENT

# Postgres (shared defaults)
DB_POSTGRES_USER=postgres
DB_POSTGRES_PASSWORD=postgres
DB_POSTGRES_HOST=localhost
DB_POSTGRES_PORT=5432
DB_POSTGRES_NAME=digisign
DB_POSTGRES_SCHEMA=
DB_POSTGRES_MAX_IDLE_CONNS=10
DB_POSTGRES_MAX_OPEN_CONNS=50
DB_POSTGRES_MAX_LIFE_TIME=5m
DB_POSTGRES_LOCATION=Asia/Jakarta
DB_POSTGRES_TIMEOUT=5s
DB_POSTGRES_FLAVOR=

# UI
VITE_API_URL=http://localhost:3001

# Auth (JWT RS256)
AUTH_JWKS_URL=
AUTH_ISSUER=
AUTH_AUDIENCE=

# Migration bootstrap (required by migrate up)
DEFAULT_SUPERADMIN_EMAIL=superadmin@example.com
DEFAULT_SUPERADMIN_PASSWORD=password123
DEFAULT_SUPERADMIN_RESET_PASSWORD=false

# Storage
STORAGE_ROOT=storage
